              </svg>
              <a href="https://wa.me/97142087112" class="transition-colors" style="color: #BAE6FD;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#BAE6FD'">+971 42087112</a>
            </li>
          </ul>

          <!-- Social Icons -->
          <div class="flex flex-wrap items-center gap-3 mt-8">
            <a href="https://www.facebook.com/raynagroup" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full flex items-center justify-center transition-all duration-200" style="border: 1px solid rgba(186, 230, 253, 0.3); color: #BAE6FD;" onmouseover="this.style.backgroundColor='#0EA5E9'; this.style.borderColor='#0EA5E9'; this.style.color='#FFFFFF';" onmouseout="this.style.backgroundColor='transparent'; this.style.borderColor='rgba(186, 230, 253, 0.3)'; this.style.color='#BAE6FD';" aria-label="Facebook">
