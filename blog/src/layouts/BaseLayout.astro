---
import '../styles/global.css';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, BASE, url } from '../utils/constants';
import { getCollection } from 'astro:content';
import GlobalSearch from '../components/GlobalSearch.tsx';
import { CITIES } from '../../scripts/cities';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// Build city guide nav data from posts that have content
const cityNamesWithContent = [...new Set(allPosts.map(p => p.data.city))];
const cityGuideList = cityNamesWithContent
  .map(name => CITIES.find(c => c.name === name))
  .filter(Boolean)
  .sort((a, b) => a!.continent.localeCompare(b!.continent) || a!.name.localeCompare(b!.name));

type CityItem = (typeof CITIES)[number];
const continentGroups = cityGuideList.reduce<Record<string, CityItem[]>>((acc, city) => {
  if (!city) return acc;
  (acc[city.continent] ??= []).push(city);
  return acc;
}, {});
const continentEntries = Object.entries(continentGroups);

// Country guide dropdown data: unique countries → grouped by continent
const countryList = cityGuideList
  .map(c => c!.country)
  .filter((v, i, a) => a.indexOf(v) === i)
  .sort();

type CountryEntry = { name: string; slug: string; continent: string };
const countryData: CountryEntry[] = countryList.map(name => {
  const city = CITIES.find(c => c.country === name);
  return {
    name,
    slug: name.toLowerCase().replace(/\s+/g, '-'),
    continent: city?.continent ?? '',
  };
});
const countryByContinentGroups = countryData.reduce<Record<string, CountryEntry[]>>((acc, c) => {
  (acc[c.continent] ??= []).push(c);
  return acc;
}, {});
const countryByContinentEntries = Object.entries(countryByContinentGroups);

const globalSearchData = allPosts.map(p => ({
  title: p.data.title,
  description: p.data.description,
  slug: p.slug,
  city: p.data.city,
  category: p.data.category,
  tags: p.data.tags ?? [],
  keywords: p.data.keywords,
  featured: p.data.featured,
  readingTime: p.data.readingTime,
}));

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  modifiedDate?: string;
  jsonLd?: Record<string, any>;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image = '/images/og-default.jpg',
  canonicalUrl = Astro.url.href,
  type = 'website',
  publishedDate,
  modifiedDate,
  jsonLd,
} = Astro.props;

const pageTitle = title === SITE_TITLE ? title : `${title} | ${SITE_TITLE}`;
const fullImageUrl = image.startsWith('http') ? image : `${SITE_URL}${image}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{pageTitle}</title>
  <meta name="title" content={pageTitle} />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href={url('favicon.svg')} />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={fullImageUrl} />
  <meta property="og:site_name" content={SITE_TITLE} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullImageUrl} />

  {publishedDate && <meta property="article:published_time" content={publishedDate} />}
  {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}

  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}
</head>

<body class="min-h-screen flex flex-col">
  <!-- Accent top bar -->
  <div class="h-1 w-full" style="background: linear-gradient(90deg, #0EA5E9, #EA580C);"></div>

  <!-- Navigation -->
  <nav class="sticky top-0 z-50 bg-white" style="border-bottom: 1px solid #BAE6FD;">
    <div class="container-wide flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={BASE} class="flex items-center py-2">
        <img src={url('raynatourslogo.svg')} alt="Rayna Tours" class="h-12 rounded-lg" />
      </a>

      <!-- Center Links -->
      <div class="hidden md:flex items-center gap-8">
        <a href={BASE} class="nav-link-editorial text-sm font-medium transition-colors py-1" style="color: #0C4A6E;">Home</a>

        <!-- City Guides dropdown -->
        <div class="group relative">
          <button class="nav-link-editorial flex items-center gap-1 text-sm font-medium transition-colors py-1" style="color: #0C4A6E;">
            City Guides
            <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:rotate-180" style="color: #0EA5E9;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown panel -->
          <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-200
                      absolute top-full left-1/2 -translate-x-1/2 pt-3 z-[200]">
            <div class="bg-white rounded-xl p-5 min-w-[300px]" style="border: 1px solid #BAE6FD; box-shadow: 0 8px 30px rgba(12, 74, 110, 0.08), 0 2px 8px rgba(12, 74, 110, 0.04);">
              {continentEntries.map(([continent, cities]) => (
                <div class="mb-4 last:mb-0">
                  <p class="text-[10px] font-semibold uppercase tracking-wider mb-2" style="color: #0EA5E9; font-family: 'Inter', sans-serif;">{continent}</p>
                  <div class="grid grid-cols-2 gap-0.5">
                    {cities.map(city => (
                      <a
                        href={url(`${city.slug}-rayna-guide`)}
                        class="flex items-center gap-2 text-sm rounded-lg px-3 py-2 transition-all duration-200"
                        style="color: #0C4A6E;"
                        onmouseover="this.style.color='#0EA5E9'; this.style.backgroundColor='#F0F9FF';"
                        onmouseout="this.style.color='#0C4A6E'; this.style.backgroundColor='transparent';"
                      >
                        <span>{city.name}</span>
                      </a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
        <!-- Country Guides dropdown -->
        <div class="group relative">
          <button class="nav-link-editorial flex items-center gap-1 text-sm font-medium transition-colors py-1" style="color: #0C4A6E;">
            Country Guides
            <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:rotate-180" style="color: #0EA5E9;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown panel -->
          <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-200
                      absolute top-full left-1/2 -translate-x-1/2 pt-3 z-[200]">
            <div class="bg-white rounded-xl p-5 min-w-[280px]" style="border: 1px solid #BAE6FD; box-shadow: 0 8px 30px rgba(12, 74, 110, 0.08), 0 2px 8px rgba(12, 74, 110, 0.04);">
              {countryByContinentEntries.map(([continent, countries]) => (
                <div class="mb-4 last:mb-0">
                  <p class="text-[10px] font-semibold uppercase tracking-wider mb-2" style="color: #0EA5E9; font-family: 'Inter', sans-serif;">{continent}</p>
                  <div class="grid grid-cols-2 gap-0.5">
                    {countries.map(country => (
                      <a
                        href={url(`${country.slug}-rayna-guide`)}
                        class="flex items-center gap-2 text-sm rounded-lg px-3 py-2 transition-all duration-200"
                        style="color: #0C4A6E;"
                        onmouseover="this.style.color='#0EA5E9'; this.style.backgroundColor='#F0F9FF';"
                        onmouseout="this.style.color='#0C4A6E'; this.style.backgroundColor='transparent';"
                      >
                        {country.name}
                      </a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <GlobalSearch articles={globalSearchData} client:load />
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-full transition-colors" style="color: #0C4A6E;" onmouseover="this.style.backgroundColor='#F0F9FF'" onmouseout="this.style.backgroundColor='transparent'" aria-label="Toggle menu">
          <!-- Hamburger icon -->
          <svg id="icon-menu" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <!-- Close icon -->
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden bg-white overflow-y-auto"
      style="max-height: calc(100vh - 4.25rem); border-top: 1px solid #BAE6FD;"
    >
      <div style="border-color: #BAE6FD;" class="divide-y">

        <!-- Home -->
        <a href={BASE} class="flex items-center px-5 py-4 text-sm font-medium transition-colors" style="color: #0C4A6E;" onmouseover="this.style.backgroundColor='#F0F9FF'; this.style.color='#0EA5E9';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#0C4A6E';">
          Home
        </a>

        <!-- Country Guides accordion -->
        <details class="group/country [&[open]_.caret-c]:rotate-180">
          <summary class="flex items-center justify-between px-5 py-4 text-sm font-medium cursor-pointer list-none select-none transition-colors" style="color: #0C4A6E;" onmouseover="this.style.backgroundColor='#F0F9FF'" onmouseout="this.style.backgroundColor='transparent'">
            Country Guides
            <svg class="caret-c w-4 h-4 transition-transform duration-200" style="color: #0EA5E9;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-4 pb-4 pt-1" style="background-color: #F0F9FF;">
            <div class="grid grid-cols-2 gap-1">
              {countryData.map(country => (
                <a
                  href={url(`${country.slug}-rayna-guide`)}
                  class="block py-2.5 px-3 text-sm rounded-lg transition-colors"
                  style="color: #0C4A6E;"
                  onmouseover="this.style.color='#0EA5E9'; this.style.backgroundColor='white';"
                  onmouseout="this.style.color='#0C4A6E'; this.style.backgroundColor='transparent';"
                >
                  {country.name}
                </a>
              ))}
            </div>
          </div>
        </details>

        <!-- City Guides accordion -->
        <details class="group/city [&[open]_.caret-ci]:rotate-180">
          <summary class="flex items-center justify-between px-5 py-4 text-sm font-medium cursor-pointer list-none select-none transition-colors" style="color: #0C4A6E;" onmouseover="this.style.backgroundColor='#F0F9FF'" onmouseout="this.style.backgroundColor='transparent'">
            City Guides
            <svg class="caret-ci w-4 h-4 transition-transform duration-200" style="color: #0EA5E9;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-4 pb-4 pt-1" style="background-color: #F0F9FF;">
            {continentEntries.map(([continent, cities]) => (
              <div class="mb-4 last:mb-0">
                <p class="text-[10px] font-semibold uppercase tracking-wider px-1 mb-1.5" style="color: #0EA5E9;">{continent}</p>
                <div class="grid grid-cols-2 gap-1">
                  {cities.map(city => (
                    <a
                      href={url(`${city.slug}-rayna-guide`)}
                      class="block py-2.5 px-3 text-sm rounded-lg transition-colors"
                      style="color: #0C4A6E;"
                      onmouseover="this.style.color='#0EA5E9'; this.style.backgroundColor='white';"
                      onmouseout="this.style.color='#0C4A6E'; this.style.backgroundColor='transparent';"
                    >
                      {city.name}
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </details>

      </div>
    </div>
  </nav>

  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer style="background-color: #0C4A6E;">
    <!-- Gradient divider line at top -->
    <div class="h-1 w-full" style="background: linear-gradient(90deg, #0EA5E9, #EA580C);"></div>

    <div class="container-wide py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-[1.4fr_1fr_1.2fr] gap-10 md:gap-20">
        <!-- Column 1: Logo & Download App -->
        <div>
          <div class="mb-5">
            <img
              src="https://d31sl6cu4pqx6g.cloudfront.net/assets/Images/AGT-06437/raynatourslogo.png"
