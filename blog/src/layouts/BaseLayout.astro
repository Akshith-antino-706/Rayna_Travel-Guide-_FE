              class="h-16 w-auto brightness-0 invert"
              loading="lazy"
            />
          </div>
          <p class="text-sm font-semibold text-white mb-4">Download App</p>
          <div class="flex items-center gap-4">
            <a href="https://play.google.com/store/apps/details?id=com.raynatours" target="_blank" rel="noopener noreferrer" class="inline-block hover:opacity-80 transition-opacity">
              <img
                src="https://d31sl6cu4pqx6g.cloudfront.net/assets/Whitelabel/svg/default/Android.png"
                alt="Get it on Google Play"
                class="h-10 w-auto"
                loading="lazy"
              />
            </a>
            <a href="https://apps.apple.com/in/app/raynatours-travel-experiences/id6446171807" target="_blank" rel="noopener noreferrer" class="inline-block hover:opacity-80 transition-opacity">
              <img
                src="https://d31sl6cu4pqx6g.cloudfront.net/assets/Whitelabel/svg/default/Apple.png"
                alt="Download on the App Store"
                class="h-10 w-auto"
                loading="lazy"
              />
            </a>
          </div>
        </div>

        <!-- Column 2: Rayna Tours links -->
        <div>
          <h4 class="text-lg font-bold text-white mb-5" style="font-family: 'Playfair Display', Georgia, serif;">Rayna Tours</h4>
          <ul class="space-y-4 text-sm">
            <li><a href="https://www.raynatours.com/about-us" class="transition-colors" style="color: #BAE6FD;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#BAE6FD'">About us</a></li>
            <li><a href="https://www.raynab2b.com/agent-registration.aspx" target="_blank" rel="noopener noreferrer" class="transition-colors" style="color: #BAE6FD;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#BAE6FD'">Partner with us</a></li>
