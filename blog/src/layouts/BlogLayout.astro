---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import TourProductCards from '../components/TourProductCards.tsx';
import { SITE_URL, BASE, url } from '../utils/constants';
import { getCityConfig, getHolidayConfig, getCruiseConfig, getYachtConfig } from '../utils/city-products';

interface Props {
  title: string;
  description: string;
  city: string;
  country: string;
  category: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  heroImageAlt?: string;
  readingTime: number;
  tags: string[];
  headings: { depth: number; slug: string; text: string }[];
  currentSlug: string;
}

const {
  title, description, city, country, category,
  pubDate, updatedDate, heroImage, heroImageAlt,
  readingTime, tags, headings, currentSlug,
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

// Deterministic author name based on title hash
const AUTHORS = [
  'Sarah Mitchell', 'James Cooper', 'Priya Sharma', 'Daniel Reeves',
  'Amelia Chen', 'Marco Rossi', 'Fatima Al-Hassan', 'Lucas Bennett',
  'Nina Patel', 'Oliver Grant', 'Elena Vasquez', 'Aiden Brooks',
];
const hash = title.split('').reduce((acc: number, c: string) => acc + c.charCodeAt(0), 0);
const authorName = AUTHORS[hash % AUTHORS.length];

const citySlug = city.toLowerCase().replace(/\s+/g, '-');
const cityProductConfig = getCityConfig(citySlug);
const cityHolidayConfig = getHolidayConfig(citySlug);
const cityCruiseConfig  = getCruiseConfig(citySlug);
const cityYachtConfig   = getYachtConfig(citySlug);

// Sidebar gallery images — reduced to 4, first image uses article hero
const sidebarImages = [
  heroImage
    ? heroImage.replace(/w=\d+/, 'w=300').replace(/h=\d+/, 'h=300')
    : 'https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=300&h=300&fit=crop&q=70',
  'https://images.unsplash.com/photo-1518684079-3c830dcef090?w=300&h=300&fit=crop&q=70',
  'https://images.unsplash.com/photo-1526495124232-a04e1849168c?w=300&h=300&fit=crop&q=70',
  'https://images.unsplash.com/photo-1580674684081-7617fbf3d745?w=300&h=300&fit=crop&q=70',
];

const fallbackImage = 'https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=800&h=450&fit=crop';

// JSON-LD
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: heroImage ? (heroImage.startsWith('http') ? heroImage : `${SITE_URL}${heroImage}`) : undefined,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate || pubDate).toISOString(),
  author: { '@type': 'Person', name: authorName },
  publisher: { '@type': 'Organization', name: 'Rayna Tours',
    logo: { '@type': 'ImageObject', url: `${SITE_URL}/favicon.svg` } },
  mainEntityOfPage: { '@type': 'WebPage', '@id': Astro.url.href },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 3, name: `${city} Travel Guide`, item: `${SITE_URL}/${citySlug}-rayna-guide` },
    { '@type': 'ListItem', position: 4, name: title },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  type="article"
  publishedDate={pubDate.toISOString()}
  modifiedDate={(updatedDate || pubDate).toISOString()}
  jsonLd={jsonLd}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <article class="container-wide py-8" style="background-color:#F0F9FF; min-height:100vh;">
    <!-- Breadcrumb -->
    <nav class="mb-6 flex items-center flex-wrap gap-1.5 text-sm" aria-label="Breadcrumb">
      <a href={BASE} class="font-medium transition-colors hover:underline" style="color:#0EA5E9;">Home</a>
      <svg class="w-3.5 h-3.5 flex-shrink-0" style="color:#BAE6FD;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <a href={BASE} class="font-medium transition-colors hover:underline" style="color:#0EA5E9;">Travel Guides</a>
      <svg class="w-3.5 h-3.5 flex-shrink-0" style="color:#BAE6FD;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <a href={url(`${citySlug}-rayna-guide`)} class="font-medium transition-colors hover:underline" style="color:#0EA5E9;">{city}</a>
      <svg class="w-3.5 h-3.5 flex-shrink-0" style="color:#BAE6FD;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <span class="truncate max-w-[220px]" style="color:#0C4A6E;">{title}</span>
    </nav>

    <!-- Article header -->
    <header class="mb-8">
      <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight mb-4" style="font-family:'Playfair Display',serif; color:#0C4A6E;">
        {title}
      </h1>

      <p class="text-base sm:text-lg leading-relaxed mb-5" style="color:#0C4A6E; opacity:0.7;">
        {description}
      </p>

      <div class="flex items-center flex-wrap gap-4 text-sm" style="color:#0C4A6E; opacity:0.6;">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color:#E8F2F8;">
            <svg class="w-4 h-4" style="color:#0EA5E9;" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" />
            </svg>
          </div>
          <span class="font-medium" style="color:#0C4A6E;">{authorName}</span>
        </div>
        <span style="color:#BAE6FD;">|</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <span style="color:#BAE6FD;">|</span>
        <span>{readingTime} min read</span>
      </div>
    </header>

    <!-- Hero Image -->
    {heroImage && (
      <div class="mb-10">
        <img
          src={heroImage}
          alt={heroImageAlt || title}
          class="w-full rounded-2xl aspect-[16/9] object-cover"
          style="box-shadow:0 4px 24px rgba(14,165,233,0.12);"
          width="1200"
          height="675"
          loading="eager"
          onerror={`this.onerror=null;this.src='${fallbackImage}';`}
        />
      </div>
    )}

    <!-- Two-column layout: Content left + Sidebar right -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10">
      <!-- Left: Article Content -->
      <div>
        <!-- Article Body wrapped in white editorial card -->
        <div class="rounded-2xl p-6 sm:p-10" style="background-color:#FFFFFF; border:1px solid #BAE6FD;">
          <div class="prose prose-sm sm:prose-base lg:prose-lg max-w-none
                      prose-headings:font-bold
                      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-5
                      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-4
                      prose-p:leading-relaxed
                      prose-a:no-underline hover:prose-a:underline
                      prose-img:rounded-xl
                      prose-table:text-sm prose-th:text-left prose-th:px-4 prose-th:py-2.5
                      prose-td:px-4 prose-td:py-2.5 prose-td:border-t"
               style="--tw-prose-headings:#0C4A6E; --tw-prose-body:#0C4A6E; --tw-prose-links:#0EA5E9; --tw-prose-bold:#0C4A6E; --tw-prose-th-bg:#E8F2F8; --tw-prose-td-borders:#BAE6FD; font-family:'Inter',sans-serif;">
            <slot />
          </div>
        </div>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="mt-8 pt-6" style="border-top:1px solid #BAE6FD;">
            <div class="flex flex-wrap gap-2.5">
              {tags.map(tag => (
                <a
                  href={url(`?q=${encodeURIComponent(tag)}`)}
                  class="text-sm font-medium px-4 py-2 rounded-full transition-all duration-200"
                  style="background-color:#E8F2F8; color:#0EA5E9; border:1px solid #BAE6FD;"
                  onmouseenter="this.style.backgroundColor='#0EA5E9';this.style.color='#FFFFFF';this.style.borderColor='#0EA5E9';"
                  onmouseleave="this.style.backgroundColor='#E8F2F8';this.style.color='#0EA5E9';this.style.borderColor='#BAE6FD';"
                >
                  {tag}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Right: Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-20 space-y-6">
          <!-- Table of Contents -->
          {headings.length > 0 && (
            <TableOfContents headings={headings} />
          )}

          <!-- Image Gallery Grid (2x2) -->
          <div class="rounded-2xl p-5" style="background-color:#FFFFFF; border:1px solid #BAE6FD;">
            <h4 class="text-xs font-semibold uppercase tracking-wider mb-3" style="color:#0C4A6E; font-family:'Playfair Display',serif;">Gallery</h4>
            <div class="image-grid-sidebar">
              {sidebarImages.map((img, i) => (
                <img
                  src={img}
                  alt={`${city} photo ${i + 1}`}
                  class="w-full aspect-square object-cover rounded-xl"
                  loading="lazy"
                />
              ))}
            </div>
          </div>

          <!-- City badge -->
          <a
            href={url(`${citySlug}-rayna-guide`)}
            class="block p-5 rounded-2xl transition-all duration-200"
            style="background-color:#FFFFFF; border:1px solid #BAE6FD;"
            onmouseenter="this.style.borderColor='#0EA5E9';this.style.boxShadow='0 4px 16px rgba(14,165,233,0.1)';"
            onmouseleave="this.style.borderColor='#BAE6FD';this.style.boxShadow='none';"
          >
            <p class="text-xs font-semibold mb-1" style="color:#0EA5E9;">Explore more</p>
            <p class="text-base font-bold" style="color:#0C4A6E; font-family:'Playfair Display',serif;">{city} Travel Guide</p>
            <p class="text-xs mt-1.5" style="color:#0C4A6E; opacity:0.6;">View all {city} articles</p>
          </a>
        </div>
      </aside>
    </div>

    <!-- Tours, Activities, Holidays, Cruises & Yachts for this city -->
    {(cityProductConfig || cityHolidayConfig || cityCruiseConfig || cityYachtConfig) && (
      <div class="mt-12">
        <TourProductCards
          tourConfig={cityProductConfig ?? undefined}
          holidayConfig={cityHolidayConfig ?? undefined}
          cruiseConfig={cityCruiseConfig ?? undefined}
          yachtConfig={cityYachtConfig ?? undefined}
          limit={6}
          client:visible
        />
      </div>
    )}

    <!-- Related Articles -->
    <div class="mt-12">
      <RelatedArticles city={city} category={category} currentSlug={currentSlug} />
    </div>
  </article>
</BaseLayout>
