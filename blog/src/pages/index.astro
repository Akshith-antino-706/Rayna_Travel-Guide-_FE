---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import BlogFilterPage from '../components/BlogFilterPage.tsx';
import SearchBar from '../components/SearchBar.tsx';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, CATEGORIES, POSTS_PER_PAGE, BASE, url } from '../utils/constants';
import { CITIES } from '../../scripts/cities';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const cities = [...new Set(allPosts.map(p => p.data.city))];

// Featured Posts: prefer featured=true, spread across cities
const featuredPosts = sortedPosts.filter(p => p.data.featured).slice(0, 4);
const featuredCities = new Set(featuredPosts.map(p => p.data.city));
const fillPosts = sortedPosts
  .filter(p => !p.data.featured && !featuredCities.has(p.data.city))
  .slice(0, 4 - featuredPosts.length);
const selectedFeatured = [...featuredPosts, ...fillPosts].slice(0, 4);

// Popular guides: deduplicated from featured section
const guidePosts = sortedPosts
  .filter(p => !selectedFeatured.some(f => f.slug === p.slug))
  .slice(0, 4);

// Serialized posts for client-side filtering
const postsData = allPosts.map(p => ({
  title: p.data.title,
  description: p.data.description,
  slug: p.slug,
  city: p.data.city,
  category: p.data.category,
  pubDate: p.data.pubDate.toISOString(),
  heroImage: p.data.heroImage,
  readingTime: p.data.readingTime,
  tags: p.data.tags,
  keywords: p.data.keywords,
  featured: p.data.featured,
}));

const searchData = postsData.map(p => ({
  title: p.title,
  description: p.description,
  slug: p.slug,
  city: p.city,
  category: p.category,
  tags: p.tags,
  keywords: p.keywords,
  featured: p.featured,
  readingTime: p.readingTime,
}));

const categories = CATEGORIES.map(c => ({ id: c.id, label: c.label, icon: c.icon }));

// Featured cities for carousel
const featuredSlugs = ['dubai', 'singapore', 'delhi', 'bangkok', 'paris', 'london', 'tokyo', 'bali', 'istanbul', 'new-york'];
const featuredCitiesList = featuredSlugs
  .map(slug => CITIES.find(c => c.slug === slug))
  .filter(Boolean);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_TITLE,
  description: SITE_DESCRIPTION,
  url: SITE_URL,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE_URL}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout title="Home" jsonLd={jsonLd}>
  <!-- 1. Hero Banner -->
  <section class="relative h-[480px] md:h-[580px] overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=1600&h=700&fit=crop&q=80"
        alt="Travel destinations"
        class="w-full h-full object-cover scale-105"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/50 to-black/30"></div>
    </div>
    <div class="container-wide relative h-full flex flex-col justify-center items-center text-center px-4">
      <p class="text-primary-300 font-medium text-sm md:text-base uppercase tracking-[0.2em] mb-4 animate-fade-in">
        Your Journey Starts Here
      </p>
      <h1 class="text-white text-4xl md:text-6xl lg:text-7xl font-bold mb-6 max-w-4xl leading-[1.1] font-heading animate-slide-up"
          style="text-shadow: 0 2px 16px rgba(0,0,0,0.4);">
        Discover More: Insights, Stories,<br class="hidden sm:block" /> and Behind-the-Scenes Exclusives
      </h1>
      <p class="text-white/70 text-base md:text-lg max-w-2xl mb-8 leading-relaxed animate-slide-up" style="animation-delay: 0.1s;">
        Curated travel guides, local secrets, and expert recommendations for the world's most captivating destinations.
      </p>
      <div class="w-full max-w-2xl animate-slide-up" style="animation-delay: 0.2s;">
        <div class="backdrop-blur-md bg-white/10 rounded-2xl p-3 border border-white/20 shadow-editorial-xl">
          <SearchBar articles={searchData} client:load />
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Most Popular Travel Guide Carousel -->
  <section class="bg-[#F0F9FF] py-16 md:py-20">
    <div class="container-wide">
      <div class="mb-8 animate-fade-in">
        <h2 class="text-2xl md:text-3xl font-bold text-foreground font-heading tracking-tight">
          Most Popular Travel Guide
        </h2>
        <div class="w-16 h-1 bg-accent-500 rounded-full mt-3"></div>
      </div>

      <div class="relative group">
        <button
          id="carousel-left"
          class="absolute -left-3 md:-left-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-primary-500 text-white rounded-full shadow-editorial flex items-center justify-center hover:bg-primary-600 hover:shadow-editorial-lg hover:scale-110 transition-all duration-300 opacity-0 group-hover:opacity-100"
          aria-label="Scroll left"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        <div id="city-carousel" class="scroll-row gap-5">
          {featuredCitiesList.map(city => (
            <a
              href={url(`${city!.slug}-rayna-guide`)}
              class="group/card relative w-40 sm:w-48 aspect-[4/5] rounded-2xl overflow-hidden flex-shrink-0 shadow-editorial hover:shadow-editorial-lg transition-all duration-500 hover:-translate-y-2"
            >
              <img
                src={`https://images.unsplash.com/${city!.unsplashId}?w=400&h=500&fit=crop&q=70`}
                alt={`${city!.name} Travel Guide`}
                class="w-full h-full object-cover group-hover/card:scale-110 transition-transform duration-700"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
              <div class="absolute bottom-4 left-4 right-4">
                <p class="text-primary-300 text-[10px] font-semibold uppercase tracking-[0.15em] mb-1">{city!.country}</p>
                <h3 class="text-white font-bold text-lg leading-snug font-heading">{city!.name}<br/>Travel Guide</h3>
              </div>
            </a>
          ))}
        </div>

        <button
          id="carousel-right"
          class="absolute -right-3 md:-right-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-primary-500 text-white rounded-full shadow-editorial flex items-center justify-center hover:bg-primary-600 hover:shadow-editorial-lg hover:scale-110 transition-all duration-300 opacity-0 group-hover:opacity-100"
          aria-label="Scroll right"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>
  </section>

  <!-- 3. Browse by Category -->
  <section class="bg-white py-16 md:py-20 border-b border-border">
    <div class="container-wide">
      <div class="mb-6">
        <h2 class="text-2xl md:text-3xl font-bold text-foreground font-heading tracking-tight">Browse by Category</h2>
        <div class="w-16 h-1 bg-accent-500 rounded-full mt-3"></div>
      </div>
      <div class="scroll-row gap-3 pb-2">
        {CATEGORIES.slice(0, 10).map(cat => (
          <a
            href={url(`?category=${encodeURIComponent(cat.id)}#all-posts`)}
            class="flex-shrink-0 flex items-center gap-2.5 px-5 py-3 bg-primary-50 rounded-full border border-primary-200
                   hover:bg-primary-500 hover:text-white hover:border-primary-500 hover:shadow-editorial
                   transition-all duration-300 text-sm text-foreground group/pill"
          >
            <span class="text-base">{cat.icon}</span>
            <span class="font-semibold whitespace-nowrap">{cat.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Featured Travel Posts — Asymmetric Editorial Grid -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container-wide">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-foreground font-heading tracking-tight">Featured Travel Posts</h2>
          <div class="w-16 h-1 bg-accent-500 rounded-full mt-3"></div>
        </div>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-12 gap-3 sm:gap-5">
        {selectedFeatured.map((post, idx) => {
          const imgSrc = post.data.heroImage ||
            'https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=600&h=800&fit=crop&q=70';
          /* Asymmetric: row 1 = 7+5, row 2 = 5+7 */
          const colClass = idx === 0 ? 'lg:col-span-7 aspect-[16/10]' : idx === 1 ? 'lg:col-span-5 aspect-[4/5]' : idx === 2 ? 'lg:col-span-5 aspect-[4/5]' : 'lg:col-span-7 aspect-[16/10]';
          return (
            <a
              href={url(`blog/${post.slug}`)}
              class={`group relative block rounded-2xl overflow-hidden shadow-editorial hover:shadow-editorial-xl transition-all duration-500 hover:-translate-y-1 ${colClass}`}
            >
              <img
                src={imgSrc}
                alt={post.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
                onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=600&h=800&fit=crop&q=70';"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-90 group-hover:opacity-100 transition-opacity duration-300" />
              <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-6">
                <span class="inline-block text-[11px] font-bold uppercase tracking-[0.15em] text-accent-400 mb-2">
                  {post.data.category}
                </span>
                <h3 class="text-white font-bold text-sm sm:text-lg leading-snug line-clamp-3 mb-2 font-heading">
                  {post.data.title}
                </h3>
                <span class="text-white/50 text-xs font-medium">{post.data.readingTime} min read</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 5. Explore Travel Guides (city grid) -->
  <section class="bg-[#F0F9FF] py-16 md:py-20">
    <div class="container-wide">
      <div class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-foreground font-heading tracking-tight">Explore Travel Guides</h2>
        <div class="w-16 h-1 bg-accent-500 rounded-full mt-3"></div>
        <p class="text-foreground/60 text-sm md:text-base mt-3">Comprehensive city guides covering attractions, food, hotels, and more</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 sm:gap-5">
        {cities.map((city, idx) => {
          const citySlug = city.toLowerCase().replace(/\s+/g, '-');
          const count = allPosts.filter(p => p.data.city === city).length;
          const cityData = CITIES.find(c => c.slug === citySlug);
          const unsplashId = cityData?.unsplashId || 'photo-1512453979798-5ea266f8880c';
          const isWide = idx === 0 || idx === 3;
          return (
            <a
              href={url(`${citySlug}-rayna-guide`)}
              class={`group relative rounded-2xl overflow-hidden shadow-editorial hover:shadow-editorial-xl transition-all duration-500 hover:-translate-y-2 ${isWide ? 'sm:col-span-2 lg:col-span-2 aspect-[16/10]' : 'aspect-[3/4]'}`}
            >
              <img
                src={`https://images.unsplash.com/${unsplashId}?w=500&h=600&fit=crop&q=70`}
                alt={city}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
              <div class="absolute bottom-5 left-5 right-5">
                {cityData?.country && (
                  <p class="text-primary-300 text-[10px] font-bold uppercase tracking-[0.15em] mb-1">{cityData.country}</p>
                )}
                <h3 class="text-white font-bold text-xl leading-snug font-heading">{city}</h3>
                <p class="text-white/50 text-xs mt-1 font-medium">{count} articles</p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 6. Popular Travel Guides -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container-wide">
      <div class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-foreground font-heading tracking-tight">Popular Travel Guides</h2>
        <div class="w-16 h-1 bg-accent-500 rounded-full mt-3"></div>
        <p class="text-foreground/60 text-sm md:text-base mt-3">Our most popular guides chosen by travelers</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-6">
        {guidePosts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            city={post.data.city}
            category={post.data.category}
            pubDate={post.data.pubDate}
            heroImage={post.data.heroImage}
            readingTime={post.data.readingTime}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 7. All Blog Posts (filterable) -->
  <div class="bg-[#F0F9FF]">
    <BlogFilterPage
      posts={postsData}
      categories={categories}
      postsPerPage={POSTS_PER_PAGE}
      client:load
    />
  </div>
</BaseLayout>

<script>
  const carousel = document.getElementById('city-carousel');
  document.getElementById('carousel-left')?.addEventListener('click', () => {
    carousel?.scrollBy({ left: -300, behavior: 'smooth' });
  });
  document.getElementById('carousel-right')?.addEventListener('click', () => {
    carousel?.scrollBy({ left: 300, behavior: 'smooth' });
  });
</script>
