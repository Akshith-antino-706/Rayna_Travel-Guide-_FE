---
interface InfoCard {
  title: string;
  description: string;
  icon: string; // 'money' | 'sim' | 'phone' | 'passport' | 'plane' | 'heart'
  color: string; // Tailwind color name
  href?: string;
}

interface Props {
  cards: InfoCard[];
  cityName: string;
}

const { cards, cityName } = Astro.props;

const bgColors: Record<string, string> = {
  green: 'bg-emerald-100',
  blue: 'bg-[#E8F2F8]',
  red: 'bg-red-100',
  purple: 'bg-purple-100',
  cyan: 'bg-cyan-100',
  pink: 'bg-pink-100',
};

const textColors: Record<string, string> = {
  green: 'text-emerald-600',
  blue: 'text-[#0EA5E9]',
  red: 'text-red-600',
  purple: 'text-purple-600',
  cyan: 'text-cyan-600',
  pink: 'text-pink-600',
};
---

<section class="py-16 sm:py-20 bg-[#F0F9FF]">
  <div class="container-wide">
    <p class="text-[#0EA5E9] text-xs sm:text-sm font-semibold uppercase tracking-wider mb-2">Essentials</p>
    <h2 class="text-2xl sm:text-3xl font-bold text-[#0C4A6E] font-heading guide-section-header">
      Essential Information
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {cards.map((card) => {
        const Tag = card.href ? 'a' : 'div';
        return (
          <Tag
            href={card.href}
            class:list={[
              'bg-white rounded-2xl p-5 sm:p-6 border border-[#BAE6FD] hover:border-[#0EA5E9] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group',
              card.href && 'cursor-pointer',
            ]}
          >
            <div class="flex items-center gap-3.5 mb-4">
              <div class={`w-11 h-11 ${bgColors[card.color] || 'bg-[#E8F2F8]'} rounded-xl flex items-center justify-center`}>
                {card.icon === 'money' && (
                  <svg class={`w-5 h-5 ${textColors[card.color]}`} fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
                  </svg>
                )}
                {card.icon === 'sim' && (
                  <svg class={`w-5 h-5 ${textColors[card.color]}`} fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" />
                  </svg>
                )}
                {card.icon === 'phone' && (
                  <svg class={`w-5 h-5 ${textColors[card.color]}`} fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                )}
                {card.icon === 'passport' && (
                  <svg class={`w-5 h-5 ${textColors[card.color]}`} fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z" />
                  </svg>
                )}
                {card.icon === 'plane' && (
                  <svg class={`w-5 h-5 ${textColors[card.color]}`} fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
                  </svg>
                )}
                {card.icon === 'heart' && (
                  <svg class={`w-5 h-5 ${textColors[card.color]}`} fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                  </svg>
                )}
              </div>
              <h3 class="font-bold text-[#0C4A6E] text-sm sm:text-base group-hover:text-[#0EA5E9] transition-colors duration-200">{card.title}</h3>
            </div>
            <p class="text-xs sm:text-sm text-[#0C4A6E]/70 leading-relaxed">{card.description}</p>
            {card.href && (
              <p class="text-xs text-[#0EA5E9] mt-3 font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all duration-300">
                Read full guide
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </p>
            )}
          </Tag>
        );
      })}
    </div>
  </div>
</section>
