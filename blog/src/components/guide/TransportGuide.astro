---
interface TransportMode {
  mode: string;
  description: string;
  cost: string;
  color: string;
}

interface Props {
  modes: TransportMode[];
  cityName: string;
  cityImage: string;
}

const { modes, cityName, cityImage } = Astro.props;

const iconBg: Record<string, string> = {
  red: 'bg-red-100',
  yellow: 'bg-yellow-100',
  green: 'bg-green-100',
  blue: 'bg-blue-100',
};

const iconText: Record<string, string> = {
  red: 'text-red-500',
  yellow: 'text-yellow-500',
  green: 'text-green-500',
  blue: 'text-blue-500',
};
---

<section class="py-16 sm:py-20 bg-[#F0F9FF]">
  <div class="container-wide">
    <p class="text-[#0EA5E9] text-xs sm:text-sm font-semibold uppercase tracking-wider mb-2">Getting Around</p>
    <h2 class="text-2xl sm:text-3xl font-bold text-[#0C4A6E] font-heading guide-section-header">
      Best ways to explore {cityName}
    </h2>
    <p class="text-[#0C4A6E]/70 mb-8 sm:mb-10 text-sm sm:text-base max-w-2xl">
      {cityName} has excellent transport options. Here's how to get around efficiently.
    </p>

    <div class="grid lg:grid-cols-2 gap-8 lg:gap-10">
      <div class="space-y-4">
        {modes.map((m, i) => (
          <div class="flex gap-4 p-4 sm:p-5 bg-white rounded-xl border border-[#BAE6FD] hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <div class="w-11 h-11 sm:w-12 sm:h-12 bg-[#0EA5E9] rounded-full flex items-center justify-center flex-shrink-0 shadow-sm">
              <span class="text-sm font-bold text-white">{i + 1}</span>
            </div>
            <div class="min-w-0">
              <div class="flex items-center gap-2.5 mb-1.5">
                <h4 class="font-bold text-[#0C4A6E] text-sm sm:text-base">{m.mode}</h4>
                <span class="text-xs text-[#0EA5E9] font-semibold bg-[#E8F2F8] px-2 py-0.5 rounded-full">{m.cost}</span>
              </div>
              <p class="text-xs sm:text-sm text-[#0C4A6E]/70 leading-relaxed">{m.description}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="hidden lg:block">
        <img
          src={cityImage}
          alt={`Getting around ${cityName}`}
          class="rounded-2xl w-full h-full object-cover shadow-lg"
          style="box-shadow: 0 8px 30px rgba(12, 74, 110, 0.12), 0 2px 8px rgba(12, 74, 110, 0.06);"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
