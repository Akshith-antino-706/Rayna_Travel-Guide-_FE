---
import { CATEGORIES } from '../utils/constants';

interface Props {
  activeCategory?: string;
}

import { BASE, url } from '../utils/constants';
const { activeCategory } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  <a
    href={BASE}
    class:list={[
      'inline-flex items-center px-4 py-2 rounded-full text-sm font-medium transition-colors',
      !activeCategory
        ? 'bg-[#0EA5E9] text-white'
        : 'bg-[#E8F2F8] text-[#0C4A6E] hover:bg-[#BAE6FD]',
    ]}
  >
    All
  </a>

  {CATEGORIES.map(cat => (
    <a
      href={url(`?category=${encodeURIComponent(cat.id)}`)}
      class:list={[
        'inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium transition-colors',
        activeCategory === cat.id
          ? 'bg-[#0EA5E9] text-white'
          : 'bg-[#E8F2F8] text-[#0C4A6E] hover:bg-[#BAE6FD]',
      ]}
    >
      <span class="text-sm">{cat.icon}</span>
      {cat.label}
    </a>
  ))}
</div>
